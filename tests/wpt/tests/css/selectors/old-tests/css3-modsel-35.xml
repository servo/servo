<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
 <head>
  <title>:last-of-type pseudo-class</title>
  <script src="/resources/testharness.js"></script>
  <script src="/resources/testharnessreport.js"></script>
  <script src="common.js"></script>
  <style type="text/css"><![CDATA[.red { background-color : red }
address { margin-bottom : 1em ; margin-left : 1em }
address:last-of-type { background-color : lime }
]]></style>
  <link rel="author" title="Daniel Glazman" href="http://glazman.org/"/>
  <link rel="author" title="Ian Hickson" href="mailto:ian@hixie.ch"/>
  <link rel="help" href="https://www.w3.org/TR/css3-selectors/#selectors"/> <!-- bogus link to make sure it gets found -->
 </head>
 <body>
<div>
<address id="t1">A first address with normal background</address>
<address id="t2">A second address with normal background</address>
<address id="t3" class="red">A third address that should have a green background</address>
This div contains 3 addresses above this sentence.</div>
<script><![CDATA[
test(function() {
  assert_not_background_color('t1', LIME);
  assert_not_background_color('t2', LIME);
  assert_background_color('t3', LIME);
}, ':last-of-type');
]]></script>
</body>
</html>
