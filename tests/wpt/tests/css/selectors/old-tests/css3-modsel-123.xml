<html xmlns="http://www.w3.org/1999/xhtml">
 <head>
  <title>NEGATED universal selector with declared namespace</title>
  <style type="text/css"><![CDATA[@namespace html url(http://www.w3.org/1999/xhtml);
@namespace a url(http://www.example.org/a);
@namespace b url(http://www.example.org/b);
div.stub > *|* { color : red ; display : block ;
                 margin-bottom : 1em }
div.stub > *|*:not(|*) { color : green }
]]></style>
  <script src="/resources/testharness.js"></script>
  <script src="/resources/testharnessreport.js"></script>
  <script src="common.js"></script>
  <link rel="author" title="Daniel Glazman" href="http://glazman.org/"/>
  <link rel="author" title="Ian Hickson" href="mailto:ian@hixie.ch"/>
  <link rel="help" href="https://www.w3.org/TR/css3-selectors/#selectors"/> <!-- bogus link to make sure it gets found -->
  <meta name="flags" content=" namespace" />
 </head>
 <body>
<div class="stub">
<address id="t1">This address should be in green characters.</address>
<s id="t2" xmlns="http://www.example.org/b">This paragraph should be in green characters.</s>
<u id="t3" xmlns="http://www.example.org/a">This paragraph should be in green characters.</u>
</div>

<script><![CDATA[
test(function() {
  assert_color('t1', GREEN);
  assert_color('t2', GREEN);
  assert_color('t3', GREEN);
}, 'NEGATED universal selector with declared namespace');
]]></script>
</body>
</html>
