  <script src="/resources/testharnessreport.js"></script>
  <script src="common.js"></script>
 </head>
 <body xmlns:a="http://www.example.org/a" xmlns:b="http://www.example.org/b">
 <div class="stub">
  <q id="t0" xmlns="http://www.example.org/a" a:title="a paragraph">This a:q element should be unstyled.</q>
  <p id="t1" title="a paragraph">This paragraph should have a green background.</p>
  <r id="t2" xmlns="http://www.example.org/b" b:title="a paragraph">This b:r element should have a green background.</r>
 </div>
  <script><![CDATA[
test(function() {
  assert_not_background_color('t0', RED);
  assert_background_color('t1', LIME);
  assert_background_color('t2', LIME);
}, 'NEGATED Attribute existence selector with declared namespace');
]]></script>
 </body>
</html>
