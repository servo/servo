<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
 <head>
  <title>Child combinator</title>
  <script src="/resources/testharness.js"></script>
  <script src="/resources/testharnessreport.js"></script>
  <script src="common.js"></script>
  <style type="text/css"><![CDATA[.white { background-color: transparent ! important; }
.red { background-color: red; }
div > p.test { background-color: lime; }]]></style>
  <link rel="author" title="Daniel Glazman" href="http://glazman.org/"/>
  <link rel="author" title="Ian Hickson" href="mailto:ian@hixie.ch"/>
  <link rel="help" href="https://www.w3.org/TR/css3-selectors/#selectors"/> <!-- bogus link to make sure it gets found -->
 </head>
 <body>
 <div>
  <p id="t1" class="red test">This paragraph should have a green background</p>
  <div>
   <p id="t2" class="red test">This paragraph should have a green background</p>
  </div>
 </div>
 <table>
  <tbody>
   <tr>
    <td>
     <p id="t3" class="white test">This paragraph should be unstyled.</p>
    </td>
   </tr>
  </tbody>
 </table>
  <script><![CDATA[
test(function() {
  assert_background_color('t1', LIME);
  assert_background_color('t2', LIME);
  assert_not_background_color('t3', LIME);
}, 'Child combinator');
]]></script>
</body>
</html>
