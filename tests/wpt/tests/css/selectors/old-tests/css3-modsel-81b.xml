 </head>
 <body>
 <p id="t1" class="green">This paragraph should have a green background.</p>
 <div>This div contains only one paragraph.
  <p id="t2">This paragraph should be unstyled.</p>
 </div>
<script><![CDATA[
test(function() {
  assert_background_color('t1', LIME);
  assert_not_background_color('t2', LIME);
}, 'NEGATED :only-child pseudo-class');
]]></script>
 </body>
