<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
 <head>
  <title>:nth-child() pseudo-class</title>
  <style type="text/css"><![CDATA[.green { background-color : lime ! important }
ul > li:nth-child(odd) { background-color : red }
ol > li:nth-child(even) { background-color : red }
table.t1 tr:nth-child(-n+4) { background-color : red }
table.t2 td:nth-child(3n+1) { background-color : red }]]></style>
  <link rel="author" title="Daniel Glazman" href="http://glazman.org/"/>
  <script src="/resources/testharness.js"></script>
  <script src="/resources/testharnessreport.js"></script>
  <script src="common.js"></script>
  <link rel="author" title="Ian Hickson" href="mailto:ian@hixie.ch"/>
  <link rel="help" href="https://www.w3.org/TR/css3-selectors/#selectors"/> <!-- bogus link to make sure it gets found -->
 </head>
 <body>
<ul>
  <li class="green" id="t1">This first list item should have a green background</li>
  <li>Second list item</li>
  <li class="green" id="t2">This third list item should have a green background</li>
  <li>Fourth list item</li>
  <li class="green" id="t3">This fifth list item should have a green background</li>
  <li>Sixth list item</li>
</ul>
<ol>
  <li>First list item</li>
  <li class="green" id="t4">This second list item should have a green background</li>
  <li>Third list item</li>
  <li class="green" id="t5">This fourth list item should have a green background</li>
  <li>Fifth list item</li>
  <li class="green" id="t6">This sixth list item should have a green background</li>
</ol>
<div>
<table border="1" class="t1">
  <tr class="green" id="t7">
<td>Green row : 1.1</td>
<td>1.2</td>
     <td>1.3</td>
</tr>
  <tr class="green" id="t8">
<td>Green row : 2.1</td>
<td>2.2</td>
     <td>2.3</td>
</tr>
  <tr class="green" id="t9">
<td>Green row : 3.1</td>
<td>3.2</td>
     <td>3.3</td>
</tr>
  <tr class="green" id="t10">
<td>Green row : 4.1</td>
<td>4.2</td>
      <td>4.3</td>
</tr>
  <tr>
<td>5.1</td>
<td>5.2</td>
<td>5.3</td>
</tr>
  <tr>
<td>6.1</td>
<td>6.2</td>
<td>6.3</td>
</tr>
</table>
<p></p>
<table class="t2" border="1">
  <tr>
<td class="green" id="t11">green cell</td>
<td>1.2</td>
<td>1.3</td>
      <td class="green" id="t12">green cell</td>
<td>1.5</td>
<td>1.6</td>
      <td class="green" id="t13">green cell</td>
<td>1.8</td>
</tr>
  <tr>
<td class="green" id="t14">green cell</td>
<td>2.2</td>
<td>2.3</td>
      <td class="green" id="t15">green cell</td>
<td>2.5</td>
<td>2.6</td>
      <td class="green" id="t16">green cell</td>
<td>2.8</td>
</tr>
  <tr>
<td class="green" id="t17">green cell</td>
<td>3.2</td>
<td>3.3</td>
      <td class="green" id="t18">green cell</td>
<td>3.5</td>
<td>3.6</td>
      <td class="green" id="t19">green cell</td>
<td>3.8</td>
</tr>
</table>
</div>
<script><![CDATA[
test(function() {
  for (let i = 1; i <= 19; i++) {
    assert_background_color(`t${i}`, LIME, `t${i} should be green`);
  }
}, 'nth-child matching elements should have green background');
]]></script>
</body>
</html>
