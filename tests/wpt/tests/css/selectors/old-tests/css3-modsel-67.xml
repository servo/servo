 <body>
<div lang="en" class="stub">
<p id="t1">This paragraph should have a green background because the
   enclosing div is in english.</p>
<p lang="en" id="t2">This paragraph should have a green background because
   it is in english.</p>
<div lang="fr">
  <p lang="en" id="t3">This paragraph should have a green background
     because it is in english.</p>
</div>
</div>
<script><![CDATA[
test(function() {
  assert_background_color('t1', 'rgb(0, 128, 0)');
  assert_background_color('t2', 'rgb(0, 128, 0)');
  assert_background_color('t3', 'rgb(0, 128, 0)');
}, "NEGATED :lang() pseudo-class");
]]></script>
</body>
